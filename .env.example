# Copie este arquivo para .env e preencha somente se quiser usar Gemini API.
GEMINI_API_KEY=

# Opcional: modelo preferencial e lista de fallbacks.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash

# Opcional: força um nome amigável para saudação, caso o usuário da máquina venha abreviado.
APP_USER_NAME=Usuário
